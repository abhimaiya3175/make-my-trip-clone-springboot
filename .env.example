# MongoDB Configuration
# For local MongoDB
MONGODB_URI=mongodb://localhost:27017/makemytrip

# For MongoDB Atlas (Cloud)
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
# MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/makemytrip

# Application Configuration
SPRING_APPLICATION_NAME=makemytrip
SERVER_PORT=8080

# CORS Settings (for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOGGING_LEVEL_COM_MAKEMYTRIP=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
