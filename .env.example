# Backend Configuration
# Copy this file to .env and fill in your actual values

# MongoDB Connection
# Local development: mongodb://localhost:27017/makemytrip
# Cloud database: Get connection string from your database administrator
MONGODB_URI=

# Server Configuration
SPRING_APPLICATION_NAME=makemytrip
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOGGING_LEVEL_COM_MAKEMYTRIP=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
